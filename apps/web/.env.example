# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: custom sign-in URL if you use hosted pages
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional modern alternative to the legacy anon JWT. If both are set, the app prefers the publishable key.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional: same value as NEXT_PUBLIC_SUPABASE_ANON_KEY but server-only (recommended on Vercel for /api routes that must not depend on client bundle inline of NEXT_PUBLIC_*).
# SUPABASE_ANON_KEY=

# Auth: add Clerk in Supabase Dashboard → Authentication → third-party, per
# https://supabase.com/docs/guides/auth/third-party/clerk
# Use the default **session** token from Clerk (`getToken()` with no custom template) unless
# you still use the old HS256 “supabase” Clerk template + shared JWT secret:
#   NEXT_PUBLIC_CLERK_USE_LEGACY_SUPABASE_JWT=1
#   NEXT_PUBLIC_CLERK_SUPABASE_JWT_TEMPLATE=supabase
# On Vercel, **do not** set only the template name; that often causes "No suitable key or wrong key type" (PGRST301) with the third-party flow.
# NEXT_PUBLIC_CLERK_USE_LEGACY_SUPABASE_JWT=1
# NEXT_PUBLIC_CLERK_SUPABASE_JWT_TEMPLATE=supabase

# Server-only: N2YO API key (never NEXT_PUBLIC_). Required for Mission Control "objects in sky" and /api/n2yo/* — add to .env.local for local dev; Next reads it at request time.
N2YO_API_KEY=

# Cesium Ion default token (optional but recommended)
NEXT_PUBLIC_CESIUM_ION_TOKEN=
