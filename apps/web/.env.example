# Clerk (https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Optional: custom sign-in URL if you use hosted pages
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# Supabase (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional modern alternative to the legacy anon JWT. If both are set, the app prefers the publishable key.
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Auth: add Clerk in Supabase Dashboard → Authentication → Sign In / Up → third-party, per https://supabase.com/docs/guides/auth/third-party/clerk
# Session tokens need a role claim. Leave NEXT_PUBLIC_CLERK_SUPABASE_JWT_TEMPLATE unset to use getToken() (session JWT). Set it only for legacy HS256 “supabase” JWT template mode.
# Optional legacy: Clerk JWT template slug (e.g. supabase) if you still use HS256 template signing against the project JWT secret.
# NEXT_PUBLIC_CLERK_SUPABASE_JWT_TEMPLATE=

# Server-only: N2YO API key (never NEXT_PUBLIC_). Required for Mission Control "objects in sky" and /api/n2yo/* — add to .env.local for local dev; Next reads it at request time.
N2YO_API_KEY=

# Cesium Ion default token (optional but recommended)
NEXT_PUBLIC_CESIUM_ION_TOKEN=
